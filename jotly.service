[Unit]
Description=Gunicorn instance to serve Jotly
After=network.target

[Service]
User=yuunjee
Group=www-data
WorkingDirectory=/home/yuunjee/Projects/web-bullet-journal
EnvironmentFile=/home/yuunjee/Projects/web-bullet-journal/.env
ExecStart=/home/yuunjee/anaconda3/envs/bullet-journal/bin/gunicorn \
          --access-logfile - \
          --workers 3 \
          --bind 127.0.0.1:8001 \
          bullet_journal.wsgi:application

[Install]
WantedBy=multi-user.target
