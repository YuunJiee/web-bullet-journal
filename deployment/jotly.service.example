[Unit]
Description=Gunicorn instance to serve Jotly
After=network.target

[Service]
User=YOUR_USERNAME
Group=www-data
WorkingDirectory=/home/YOUR_USERNAME/Projects/web-bullet-journal
Environment="PATH=/home/YOUR_USERNAME/miniconda3/envs/bullet-journal/bin"
EnvironmentFile=/home/YOUR_USERNAME/Projects/web-bullet-journal/.env
ExecStart=/home/YOUR_USERNAME/miniconda3/envs/bullet-journal/bin/gunicorn \
    --access-logfile - \
    --workers 3 \
    --bind unix:/home/YOUR_USERNAME/Projects/web-bullet-journal/jotly.sock \
    bullet_journal.wsgi:application

[Install]
WantedBy=multi-user.target
